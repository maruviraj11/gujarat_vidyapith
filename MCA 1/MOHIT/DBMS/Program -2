1. Create Supplier Table(s).
>> Create table s(sno char(3) primary key,sname varchar(50),s_status int,s_city varchar(25));

2. Create Part Table(p).
>> Create table p(pno char(3) primary key,pname varchar(20),color varchar(10),weight float(5,2) , p_city varchar(25));

3. Create Shipment table(sp).
>> Create table sp(sno char(3) , pno char(3) , qty int , primary(sno,pno));

